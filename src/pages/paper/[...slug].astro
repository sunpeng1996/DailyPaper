---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const papers = await getCollection('papers');
  return papers.map(p => ({ params: { slug: p.slug }, props: { paper: p } }));
}

const { paper } = Astro.props;
const { Content } = await paper.render();
const data = paper.data;
const published = data.published.toISOString().slice(0, 10);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const direction = (data.direction || '').trim();
// 一键深读：跳到预填好的 GitHub Issue 表单（paper_url 自动填入），提交后 Action 自动深读归档
const deepReadUrl =
  'https://github.com/sunpeng1996/DailyPaper/issues/new'
  + '?template=deep-read.yml'
  + '&title=' + encodeURIComponent('深读: ' + data.arxiv_id)
  + '&paper_url=' + encodeURIComponent(data.url);
const affiliations = (data.affiliations || []).slice(0, 6);
const stripMd = (s) => s.replace(/\*\*/g, '').replace(/`/g, '').trim();
const pvLines = (data.practical_value || '')
  .split('\n')
  .map((l) => stripMd(l.replace(/^\s*[-*•]\s*/, '')))
  .filter((l) => l.length > 0);
---
<BaseLayout title={data.title} description={data.one_liner}>
  <article class="detail">
    <div class="meta">
      <a href={`${base}/category/${data.category}`}>{data.category}</a>
      <span class="sep">|</span>
      <time datetime={published}>{published}</time>
      <span class="sep">|</span>
      arXiv:<a href={data.url} target="_blank" rel="noopener">{data.arxiv_id}</a>
      {data.depth === 'full_pdf' && <><span class="sep">|</span><span>★ 深度解读</span></>}
    </div>
    <h1>{data.title}</h1>
    {data.title_zh && <p class="title-zh">{data.title_zh}</p>}
    <div class="dir-row">
      <span class="direction-chip">🧭 {direction || data.category}</span>
    </div>
    {affiliations.length > 0 && (
      <p class="affiliations">{affiliations.join(' · ')}</p>
    )}
    {data.authors.length > 0 && (
      <div class="meta">{data.authors.slice(0, 6).join(', ')}{data.authors.length > 6 ? ' 等' : ''}</div>
    )}
    <p class="one-liner">{data.one_liner}</p>
    <div class="tags" style="margin: 6px 0 18px;">
      {data.tags.map(t => (
        <a class="tag" href={`${base}/tag/${t}`}>{t}</a>
      ))}
    </div>
    {pvLines.length > 0 && (
      <div class="pv-block">
        <h3>📌 工作参考价值</h3>
        <ul>
          {pvLines.map((l) => <li>{l}</li>)}
        </ul>
      </div>
    )}
    <div class="content">
      <Content />
    </div>
    <div class="ext-links">
      <a href={deepReadUrl} target="_blank" rel="noopener" class="deep-read-btn">🔬 一键深读归档</a>
      <a href={data.url} target="_blank" rel="noopener">arXiv 摘要页</a>
      {data.pdf_url && <a href={data.pdf_url} target="_blank" rel="noopener">PDF</a>}
      <a href={`${base}/`}>← 返回首页</a>
    </div>
  </article>
</BaseLayout>
