---
const RESUME_URL = "https://sunpeng1996.github.io/DailyPaper/";
---
<aside class="sidebar">
  <div class="profile-card">
    <a href={RESUME_URL} class="profile-avatar" target="_blank" rel="noopener" aria-label="DailyPaper">DP</a>
    <h3 class="profile-name">DailyPaper</h3>
    <p class="profile-tagline">Agent · Multimodal · Post-training · GenRec</p>
  </div>

  <nav class="sidebar-section quick-nav" id="quick-nav" hidden>
    <h4 class="sidebar-h">本页导航</h4>
    <ul class="quick-nav-list" id="quick-nav-list"></ul>
  </nav>

  <nav class="sidebar-section">
    <h4 class="sidebar-h">个人链接</h4>
    <ul class="sidebar-links">
      <li>
        <a href={RESUME_URL} target="_blank" rel="noopener">
          <span class="link-icon">📄</span> DailyPaper 站点
        </a>
      </li>
    </ul>
  </nav>

  <section class="sidebar-section">
    <h4 class="sidebar-h">关于本站</h4>
    <p class="sidebar-text">
      面向电商 / Agent / 生成式推荐方向的每日 AI 论文与行业动态精选，
      侧重可落地到业务的信息。数据来自 arXiv、Hugging Face Daily Papers、
      Hacker News、Reddit 及主流中文 AI 媒体。
    </p>
  </section>
</aside>

<script>
  // Build a per-page "quick locate" list from the section modules in <main>.
  // Runs after DOM parse; adapts to whatever the daily pipeline rendered.
  (function () {
    var main = document.querySelector('main.content');
    var nav = document.getElementById('quick-nav');
    var list = document.getElementById('quick-nav-list');
    if (!main || !nav || !list) return;

    var items = [];
    var banner = main.querySelector('.today-banner');
    if (banner) items.push({ el: banner, label: '今日播报' });
    main.querySelectorAll('.section-h').forEach(function (h) {
      var label = (h.textContent || '').split('·')[0].trim();
      if (label) items.push({ el: h, label: label });
    });
    // Detail / archive pages: fall back to in-article headings.
    if (items.length === 0) {
      main.querySelectorAll('.detail .content h2, .archive-detail .content h2').forEach(function (h) {
        var label = (h.textContent || '').trim();
        if (label) items.push({ el: h, label: label });
      });
    }
    if (items.length < 2) return; // not worth a TOC for a single anchor

    var links = [];
    items.forEach(function (it, i) {
      if (!it.el.id) it.el.id = 'qn-' + i;
      var li = document.createElement('li');
      var a = document.createElement('a');
      a.href = '#' + it.el.id;
      a.textContent = it.label;
      a.addEventListener('click', function (e) {
        e.preventDefault();
        it.el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        history.replaceState(null, '', '#' + it.el.id);
      });
      li.appendChild(a);
      list.appendChild(li);
      links.push(a);
    });
    nav.hidden = false;

    // Scroll-spy: highlight the section currently nearest the top.
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) {
          if (!en.isIntersecting) return;
          var i = items.findIndex(function (x) { return x.el === en.target; });
          if (i < 0) return;
          links.forEach(function (l, j) { l.classList.toggle('active', j === i); });
        });
      }, { rootMargin: '-10% 0px -75% 0px', threshold: 0 });
      items.forEach(function (it) { io.observe(it.el); });
    }
  })();
</script>
