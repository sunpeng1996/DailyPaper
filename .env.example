# DeepSeek (OpenAI 兼容协议)
# 在 https://platform.deepseek.com/ -> API Keys 创建一把
DEEPSEEK_API_KEY=sk-...

# 默认指向官方 endpoint，自托管/代理时改这里
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 模型名。DeepSeek API 用全小写：deepseek-v4-pro / deepseek-v4-flash 等
DEEPSEEK_MODEL=deepseek-v4-pro

# --- 飞书推送（两条路径，IM API 优先；填一组即可）---

# A. 自定义群机器人 (最简单)
# 群设置 -> 群机器人 -> 添加自定义机器人，复制 webhook 链接
FEISHU_WEBHOOK=
# 「签名校验」开启时填，不开留空
FEISHU_SECRET=

# B. 自建应用 + IM API (需要应用权限 im:message:send_as_bot)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 目标群 chat_id（oc_xxx 格式）。发多个群用英文逗号分隔：oc_aaa,oc_bbb,oc_ccc
FEISHU_CHAT_ID=
# 默认 chat_id；其他值: open_id / user_id / union_id / email
# FEISHU_RECEIVE_ID_TYPE=chat_id
# 卡片头部配色: blue/wathet/turquoise/green/yellow/orange/red/carmine/violet/purple/indigo/grey
# FEISHU_CARD_TEMPLATE=indigo

# 站点公开 URL（用于消息卡片里的「打开站点」按钮、sitemap）
SITE_URL=https://your-github-username.github.io
BASE_PATH=/ai-papers-daily

# 一些可调参数。MAX_PAPERS_PER_DAY 建议 5-10：超过 5 浏览体验下降
MAX_PAPERS_PER_DAY=5
# 过线分数；低于此分但 MIN_PAPERS_PER_DAY 不够时会按分数保底回填
MIN_SCORE_KEEP=6
# 每天至少出几篇（即使没几篇过线也按 top 分数补满，保证卡片不空）
MIN_PAPERS_PER_DAY=5
MIN_SCORE_DEEP=8

# PDF 全文最多送给模型多少字符（避免炸 context）
PDF_TEXT_MAX_CHARS=60000

# DeepSeek 计价（元 / 百万 token），用于卡片底部「本次消息耗费」估算
# V4 实际单价以 DeepSeek 平台为准，按你账单调这几个值
PRICE_PRO_IN=2.0
PRICE_PRO_OUT=8.0
PRICE_FLASH_IN=0.5
PRICE_FLASH_OUT=2.0

# 抓取规模（debug 时调小，正式生产可不填走默认）
# ARXIV_PER_CAT=80
# HF_LIMIT=50

# 今日热门 AI 项目（GitHub 仓库）
# GITHUB_TOKEN：可选。GitHub Actions 内置自动提供（无需手动建）；
# 本地不填走匿名 60/hr（一次跑约 13 次调用够用），填了走 5000/hr
GITHUB_TOKEN=
# REPOS_RISING_DAYS=21      新建仓库窗口
# REPOS_RISING_MIN_STARS=80
# REPOS_ACTIVE_MIN_STARS=800
# REPOS_OUT_MAX=8           最终展示几个
